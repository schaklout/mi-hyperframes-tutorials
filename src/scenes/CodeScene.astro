---
import { createHighlighter } from 'shiki';
import type { TutorialStep } from '../utils/types';

interface Props {
  id: string;
  code: string;
  language: string;
  start: number;
  duration: number;
  steps: TutorialStep[];
}

const { id, code, language, start, duration, steps } = Astro.props;

const highlighter = await createHighlighter({
  themes: ['tokyo-night'],
  langs: [language],
});

const html = highlighter.codeToHtml(code, {
  lang: language,
  theme: 'tokyo-night'
});
---

<div 
  id={id} 
  class="clip code-scene" 
  data-start={start} 
  data-duration={duration} 
  data-track-index="1"
>
  <!-- Cinematic Background Layer -->
  <div class="bg-layer"></div>

  <div class="editor-window">
    <div class="editor-header">
      <div class="dots">
        <span></span><span></span><span></span>
      </div>
      <div class="filename">script.{language === 'javascript' ? 'js' : language}</div>
    </div>
    <div class="code-content" set:html={html} />
  </div>

  <div class="callouts-layer">
    {steps.map((step, index) => (
      <div 
        id={`callout-${index}`}
        class="clip callout" 
        data-line={step.line}
      >
        <div class="callout-pointer"></div>
        <div class="callout-content">
          <p>{step.explanation}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<style is:global>
  .code-scene {
    width: 100%;
    height: 100%;
    background: #0a0c10;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .bg-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 50%, #1a1b26 0%, #0a0c10 100%);
    opacity: 0.8;
    z-index: 0;
  }

  .editor-window {
    width: 1100px;
    background: #1a1b26;
    border-radius: 20px;
    box-shadow: 0 80px 160px rgba(0,0,0,0.8);
    border: 1px solid rgba(41, 46, 66, 0.8);
    position: relative;
    z-index: 2;
    overflow: hidden;
  }

  .editor-header {
    background: #16161e;
    padding: 22px 30px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid #292e42;
  }

  .dots { display: flex; gap: 12px; }
  .dots span {
    width: 14px; height: 14px; border-radius: 50%;
  }
  .dots span:nth-child(1) { background: #ff5f56; box-shadow: 0 0 10px rgba(255, 95, 86, 0.3); }
  .dots span:nth-child(2) { background: #ffbd2e; box-shadow: 0 0 10px rgba(255, 189, 46, 0.3); }
  .dots span:nth-child(3) { background: #27c93f; box-shadow: 0 0 10px rgba(39, 201, 63, 0.3); }

  .filename {
    margin-left: 28px;
    font-family: 'Inter', sans-serif;
    color: #7982a9;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .code-content {
    padding: 60px;
    font-family: 'Fira Code', monospace;
    font-size: 36px;
    line-height: 1.6;
    font-variant-ligatures: contextual;
  }

  .code-content pre {
    background: transparent !important;
    margin: 0 !important;
  }

  .callouts-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 10;
  }

  .callout {
    position: absolute;
    left: 1480px; 
    width: 440px;
    opacity: 0;
  }

  .callout-content {
    background: rgba(36, 40, 59, 0.95);
    backdrop-filter: blur(12px);
    padding: 35px;
    border-radius: 28px;
    border: 1px solid rgba(65, 72, 104, 0.8);
    box-shadow: 0 40px 80px rgba(0,0,0,0.5);
    position: relative;
  }

  .callout-content p {
    font-family: 'Inter', sans-serif;
    color: #e0e0e0;
    font-size: 24px;
    line-height: 1.5;
    font-weight: 400;
  }

  .callout-pointer {
    position: absolute;
    left: -50px;
    top: 50%;
    width: 50px;
    height: 2px;
    background: linear-gradient(to right, transparent, rgba(65, 72, 104, 0.8));
  }

  .code-content span {
    display: inline-block;
  }

  .shiki .line {
    display: block;
    width: 100%;
    padding: 0 15px;
    margin: 0 -15px;
    border-radius: 8px;
    transition: background-color 0.4s ease;
  }
</style>
