---
import { createHighlighter } from 'shiki';
import type { TutorialStep } from '../utils/types';

interface Props {
  id: string;
  code: string;
  language: string;
  start: number;
  duration: number;
  steps: TutorialStep[];
}

const { id, code, language, start, duration, steps } = Astro.props;

const highlighter = await createHighlighter({
  themes: ['rose-pine'],
  langs: [language],
});

const html = highlighter.codeToHtml(code, {
  lang: language,
  theme: 'rose-pine'
});
---

<div 
  id={id} 
  class="clip code-scene" 
  data-start={start} 
  data-duration={duration} 
  data-track-index="1"
>
  <!-- Cinematic Background Layer -->
  <div class="bg-layer"></div>

  <div class="editor-window">
    <div class="editor-header">
      <div class="dots">
        <span></span><span></span><span></span>
      </div>
      <div class="filename">script.{language === 'javascript' ? 'js' : language}</div>
    </div>
    <div class="code-content" set:html={html} />
  </div>

  <div class="callouts-layer">
    {steps.map((step, index) => (
      <div 
        id={`callout-${index}`}
        class="clip callout" 
        data-line={step.line}
      >
        <div class="callout-pointer"></div>
        <div class="callout-content">
          <p>{step.explanation}</p>
        </div>
      </div>
    ))}
  </div>
</div>

<style is:global>
  .code-scene {
    width: 100%;
    height: 100%;
    background: #0d0d0d;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
    perspective: 1500px;
  }

  .bg-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
      radial-gradient(circle at 20% 20%, rgba(244, 114, 182, 0.15) 0%, transparent 40%),
      radial-gradient(circle at 80% 80%, rgba(251, 191, 36, 0.1) 0%, transparent 40%),
      radial-gradient(circle at 50% 50%, #1a1a1a 0%, #0d0d0d 100%);
    opacity: 1;
    z-index: 0;
  }

  .editor-window {
    width: 1100px;
    background: rgba(26, 26, 26, 0.9);
    backdrop-filter: blur(20px);
    border-radius: 24px;
    box-shadow: 
      -20px 40px 80px rgba(0,0,0,0.6),
      0 0 0 1px rgba(244, 114, 182, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.1);
    position: relative;
    z-index: 2;
    overflow: hidden;
    transform: rotateY(-12deg) rotateX(4deg) translateZ(50px);
    transform-style: preserve-3d;
  }

  .editor-header {
    background: rgba(30, 30, 30, 0.8);
    padding: 22px 30px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid rgba(244, 114, 182, 0.15);
  }

  .dots { display: flex; gap: 12px; }
  .dots span {
    width: 14px; height: 14px; border-radius: 50%;
  }
  .dots span:nth-child(1) { background: #f472b6; box-shadow: 0 0 15px rgba(244, 114, 182, 0.4); }
  .dots span:nth-child(2) { background: #fbbf24; box-shadow: 0 0 15px rgba(251, 191, 36, 0.4); }
  .dots span:nth-child(3) { background: rgba(255, 255, 255, 0.2); }

  .filename {
    margin-left: 28px;
    font-family: 'Inter', sans-serif;
    color: #a1a1aa;
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.5px;
  }

  .code-content {
    padding: 60px;
    font-family: 'Fira Code', monospace;
    font-size: 36px;
    line-height: 1.6;
    font-variant-ligatures: contextual;
    transform: translateZ(30px);
  }

  .code-content pre {
    background: transparent !important;
    margin: 0 !important;
  }

  .callouts-layer {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 10;
  }

  .callout {
    position: absolute;
    left: 1480px; 
    width: 440px;
    opacity: 0;
  }

  .callout-content {
    background: rgba(25, 25, 25, 0.85);
    backdrop-filter: blur(16px);
    padding: 35px;
    border-radius: 28px;
    border: 1px solid rgba(251, 191, 36, 0.4);
    box-shadow: 
      0 30px 60px rgba(0,0,0,0.5),
      0 0 20px rgba(251, 191, 36, 0.1);
    position: relative;
  }

  .callout-content p {
    font-family: 'Inter', sans-serif;
    color: #fde68a;
    font-size: 24px;
    line-height: 1.5;
    font-weight: 500;
  }

  .callout-pointer {
    position: absolute;
    left: -50px;
    top: 50%;
    width: 50px;
    height: 2px;
    background: linear-gradient(to right, transparent, rgba(251, 191, 36, 0.6));
  }

  .code-content span {
    display: inline-block;
  }

  .shiki .line {
    display: block;
    width: 100%;
    padding: 0 15px;
    margin: 0 -15px;
    border-radius: 8px;
    transition: background-color 0.4s ease;
  }
</style>
